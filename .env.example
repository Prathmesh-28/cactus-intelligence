# Frontend (safe to expose — these are public keys)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Edge Function secrets (set via: supabase secrets set KEY=value) ──────────
# NEVER put these in .env.local — set them in Supabase dashboard only
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# LUSHA_API_KEY=1eb19877-5ec9-43bd-a72e-c2c593ee6063
